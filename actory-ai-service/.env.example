PORT=8000
HOST=0.0.0.0
MODEL_PATH=models/fea-iter-2.keras
HAAR_CASCADE_PATH=haarcascade_frontalface_default.xml
LOG_LEVEL=INFO
REQUIRE_VOICE_ANALYSIS=false
